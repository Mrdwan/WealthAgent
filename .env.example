# WealthAgent — environment variable template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ────────────────────────────────────────────────────────────────

# Tiingo API key for price history and fundamentals
# https://www.tiingo.com/account/api/token
TIINGO_API_KEY=

# Anthropic API key for Claude (opus model used for deep analysis)
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Telegram bot token — get one from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — send /start to @userinfobot to find it
TELEGRAM_CHAT_ID=

# ── LLM ─────────────────────────────────────────────────────────────────────

# Ollama service URL (default: Docker service name)
OLLAMA_BASE_URL=http://ollama:11434

# Local model pulled into Ollama for fast/cheap inference
OLLAMA_MODEL=gemma4:e4b

# Claude model used for high-quality analysis
OPUS_MODEL=claude-opus-4-6

# ── Storage ──────────────────────────────────────────────────────────────────

# Path to the SQLite database file inside the container
DB_PATH=/app/data/wealthagent.db

# Directory for log files
LOG_DIR=/app/logs

# ── Portfolio ────────────────────────────────────────────────────────────────

# Monthly investment budget in EUR
MONTHLY_BUDGET_EUR=2000

# Fraction of monthly budget allocated to long-term positions (0–1)
LONG_TERM_PCT=0.75

# Fraction of monthly budget allocated to short-term positions (0–1)
SHORT_TERM_PCT=0.25

# ── Tax (Irish CGT defaults — adjust for your jurisdiction) ──────────────────

# Capital gains tax rate (0–1)
CGT_RATE=0.33

# Annual CGT exemption in EUR
ANNUAL_EXEMPTION=1270

# ── Alert thresholds ─────────────────────────────────────────────────────────

# Alert if a holding drops more than this percentage in 30 days
ALERT_DROP_PCT=10

# Exit a short-term position if it drops more than this percentage from entry
STOP_LOSS_PCT=8

# De-prioritise stocks with dividend yield above this value
DIVIDEND_YIELD_MAX=2.0
